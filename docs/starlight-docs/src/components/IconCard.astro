---
interface Props {
  title: string;
  items: string[];
  href?: string;
  icon?: string;
}

const { title, items, href, icon } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag href={href} style="border: 1px solid var(--sl-color-gray-5); border-radius: 0.5rem; padding: 1rem; display: block; text-decoration: none; color: inherit; transition: border-color 0.15s;">
  <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem;">
    {icon && <img src={icon} alt="" width="24" height="24" style="flex-shrink: 0;" class="icon-card-icon" />}
    <span style="font-size: var(--sl-text-base); font-weight: 600;">{title}</span>
  </div>
  <ul style="margin: 0; padding: 0 0 0 1.2rem; font-size: var(--sl-text-body); line-height: 1.6;">
    {items.map(item => <li style="margin: 0; padding: 0;">{item}</li>)}
  </ul>
</Tag>

<style>
  a:hover {
    border-color: var(--sl-color-accent) !important;
  }
  :global([data-theme='dark']) .icon-card-icon {
    filter: invert(1) brightness(2);
  }
</style>
