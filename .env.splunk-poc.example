# Splunk Distribution POC — credentials + demo-app redirect
#
# Copy this file to .env.splunk-poc and fill in your Splunk Observability Cloud values.
# The actual .env.splunk-poc is gitignored and must never be committed.
#
# Where to find these in Splunk Observability Cloud:
#   Access Token:  Organization → Access Tokens → any token with ingest scope
#   Realm:         Visible in your Splunk Observability Cloud URL
#                  (e.g. us0, us1, eu0, au0)
#   HEC Token:     Data Management → Connect Data → HTTP Event Collector
#                  (if absent, can often fall back to the Access Token)

# --- Splunk credentials ---
SPLUNK_ACCESS_TOKEN=your-splunk-access-token-here
SPLUNK_REALM=us1
SPLUNK_HEC_TOKEN=your-hec-token-here-or-reuse-access-token

# --- Redirect demo apps through Splunk collector (the tee) ---
# Demo apps read OTEL_COLLECTOR_HOST to build OTEL_EXPORTER_OTLP_ENDPOINT.
# Overriding it to the Splunk collector's service name routes all telemetry through
# the Splunk distribution first; Splunk then fans out to Splunk Observability Cloud
# and forwards a copy via OTLP back to the base otel-collector for OpenSearch.
OTEL_COLLECTOR_HOST=splunk-otel-collector

# --- Splunk collector image pin (optional) ---
SPLUNK_COLLECTOR_VERSION=latest
